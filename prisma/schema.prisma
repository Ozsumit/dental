generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id            String        @id @default(uuid())
  firstName     String
  lastName      String
  phone         String
  email         String?
  dateOfBirth   DateTime
  gender        String?
  status        String        @default("ACTIVE")
  
  // Medical Records
  bloodType     String?
  allergies     String?
  medicalNotes  String?
  
  lastVisitDate DateTime?
  visitCount    Int           @default(0)

  appointments  Appointment[]
  procedures    Procedure[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([firstName, lastName])
  @@index([phone])
  @@index([status])
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  appointmentDate DateTime
  status          String
  treatments      String // In SQLite we'll store this as a JSON string or comma-separated
  
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
}

model Procedure {
  id            String   @id @default(uuid())
  patientId     String
  name          String
  description   String?
  cost          Float    @default(0)
  procedureDate DateTime @default(now())

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}