generator client {
  provider = "prisma-client-js"
  experimentalFeatures = ["clientExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String           @id @default(uuid())
  name           String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  users          User[]
  patients       Patient[]
  appointments   Appointment[]
  billingCatalog BillingCatalog[]
  procedures     Procedure[]
  systemSettings SystemSettings[]
  taxonomies     Taxonomy[]
}

model User {
  id                  String          @id @default(uuid())
  username            String          @unique
  password            String
  role                Role            @default(RECEPTIONIST)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  appointments        Appointment[]   @relation("DoctorAppointments")
  assignedRecords     MedicalRecord[]
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id])

  // Doctor settings and profile fields
  fullName            String?
  dateOfBirth         DateTime?
  phone               String?
  email               String?
  specialization      String?
  nmcRegNo            String?
  photoUrl            String?
  notifyAppointment   Boolean         @default(false)
  notifyWaiting       Boolean         @default(true)
  notifyLabResults    Boolean         @default(false)
  notifyDraftReminder Boolean         @default(true)
  notifyDailySummary  Boolean         @default(false)
  requireOtp          Boolean         @default(false)

  @@index([tenantId])
}

model Patient {
  id            String         @id @default(uuid())
  firstName     String         @db.Citext
  lastName      String         @db.Citext
  phone         String         @db.Citext
  email         String?        @db.Citext
  dateOfBirth   DateTime
  gender        String?
  status        String         @default("ACTIVE")
  address       String?
  role          String?
  bloodGroup    String?
  allergies     String?
  isOld         Boolean        @default(false)
  lastVisitDate DateTime?
  visitCount    Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  diagnoses     Diagnosis[]
  medicalRecord MedicalRecord?
  assessments   ClinicalAssessment[]

  
  // Family linking fields
  primaryAccountId String?
  primaryAccount   Patient?       @relation("FamilyLink", fields: [primaryAccountId], references: [id], onDelete: SetNull)
  familyMembers    Patient[]      @relation("FamilyLink")
  familyRelation   String?        // e.g. "Spouse", "Child", "Parent", "Other"

  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  procedures    Procedure[]

  @@index([firstName, lastName])
  @@index([phone])
  @@index([status])
  @@index([tenantId])
  @@unique([phone, tenantId])
  @@unique([email, tenantId])
}

model MedicalRecord {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  assignedDoctorId     String?
  complaints           String?
  insurance            String?
  insuranceNo          String?
  emergencyContactName String?
  emergencyContactNo   String?
  status               String?
  title                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  assignedDoctor       User?    @relation(fields: [assignedDoctorId], references: [id])
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicalHistory       Json?
}

model Diagnosis {
  id               String    @id @default(uuid())
  patientId        String
  currentComplaint String?
  pastHistory      String?
  medicalHistory   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  currentHistory   String?
  homeExercise     String?
  icd10Code        String?
  nextVisitDate    DateTime?
  treatmentPlan    String?
  vasScore         Int?      @default(0)
  medicines        String?
  objectiveData    String?
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assessment       ClinicalAssessment?

  @@index([patientId])
}

model ClinicalAssessment {
  id                     String                  @id @default(uuid())
  patientId              String
  diagnosisId            String                  @unique
  toothChart             String?
  oralHygiene            String?
  tmj                    String?
  biteOcclusion          String?
  softTissue             String?
  generalExam            String?
  diagnosticProcs        String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  assessmentRequirements AssessmentRequirement[] @relation("ClinicalAssessmentRequirements")
  patient                Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnosis              Diagnosis               @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

// Assessment requirement definitions
model AssessmentRequirement {
  id                  String               @id @default(uuid())
  name                String
  description         String?
  isRequired          Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  clinicalAssessments ClinicalAssessment[] @relation("ClinicalAssessmentRequirements")
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String?
  appointmentDate DateTime
  status          String
  treatments      String
  isPaid          Boolean  @default(false)
  billAmount      Float    @default(0)
  createdAt       DateTime @default(now())
  doctor          User?    @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedures      Procedure[]
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model BillingCatalog {
  id          String   @id @default(uuid())
  name        String
  category    String?
  baseCost    Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Procedure {
  id            String   @id @default(uuid())
  patientId     String
  appointmentId String?
  name          String
  type          String?
  description   String?
  cost          Float    @default(0)
  procedureDate DateTime @default(now())
  medicine      String?
  suggestions   String?
  status        String   @default("PENDING")
  billedById    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model SystemSettings {
  id             String   @id @default(uuid())
  appointmentFee Float    @default(0)
  updatedAt      DateTime @updatedAt
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model Taxonomy {
  id        String   @id @default(uuid())
  group     String // e.g. "MEDICAL_HISTORY", "EXAMINATION", "PROBLEM", "DIAGNOSIS", "INVESTIGATION", "TREATMENT"
  category  String? // e.g. "Systemic Diseases"
  label     String
  value     String
  metadata  Json? // { type: "critical", placeholder: "...", options: ["..."] }
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([group, value, tenantId])
  @@index([tenantId])
  @@index([group])
}

enum Role {
  SUPERADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
}

