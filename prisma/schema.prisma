generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

model User {
  id               String          @id @default(uuid())
  username         String          @unique
  password         String
  role             Role            @default(RECEPTIONIST)
  assignedRecords  MedicalRecord[]
  appointments     Appointment[]   @relation("DoctorAppointments")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Patient {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  phone         String
  email         String?
  dateOfBirth   DateTime
  gender        String?
  status        String         @default("ACTIVE")
  address       String?
  role          String?        // Patient category or role
  bloodGroup    String?
  allergies     String?        // Comma separated allergies
  isOld         Boolean        @default(false)
  
  medicalRecord MedicalRecord?
  diagnosis     Diagnosis?
  
  lastVisitDate DateTime?
  visitCount    Int            @default(0)

  appointments  Appointment[]
  procedures    Procedure[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([firstName, lastName])
  @@index([phone])
  @@index([status])
}

model MedicalRecord {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  assignedDoctorId     String?
  complaints           String?
  insurance            String?
  insuranceNo          String?
  emergencyContactName String?
  emergencyContactNo   String?
  status               String?
  title                String?

  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assignedDoctor       User?    @relation(fields: [assignedDoctorId], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Diagnosis {
  id                String   @id @default(uuid())
  patientId         String   @unique
  currentComplaint  String?
  pastHistory       String?
  medicalHistory    String?  // Stored as JSON string

  // New fields for overhauled doctor view
  currentHistory    String?
  vasScore          Int?     @default(0)
  icd10Code         String?
  treatmentPlan     String?
  homeExercise      String?
  nextVisitDate     DateTime?

  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String?
  appointmentDate DateTime
  status          String
  treatments      String // Stored as JSON string or comma-separated
  
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User?    @relation("DoctorAppointments", fields: [doctorId], references: [id])

  createdAt       DateTime @default(now())
}

model Procedure {
  id            String   @id @default(uuid())
  patientId     String
  name          String
  type          String?  // e.g. Standard, Urgent, Follow-up
  description   String?
  cost          Float    @default(0)
  procedureDate DateTime @default(now())
  medicine      String?  // Stored as JSON string
  suggestions   String?  // Stored as JSON string

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
