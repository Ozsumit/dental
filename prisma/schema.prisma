generator client {
  provider = "prisma-client-js"
  experimentalFeatures = ["clientExtensions"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  patients        Patient[]
  billingCatalog  BillingCatalog[]
  systemSettings  SystemSettings[]
  appointments    Appointment[]
  procedures      Procedure[]
}

model User {
  id              String          @id @default(uuid())
  organizationId  String
  username        String          @unique
  password        String
  role            Role            @default(RECEPTIONIST)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  organization    Organization    @relation(fields: [organizationId], references: [id])
  appointments    Appointment[]   @relation("DoctorAppointments")
  assignedRecords MedicalRecord[]
}

model Patient {
  id             String         @id @default(uuid())
  organizationId String
  firstName      String
  lastName       String
  phone          String         @unique
  email          String?        @unique
  dateOfBirth    DateTime
  gender         String?
  status         String         @default("ACTIVE")
  address        String?
  role           String?
  bloodGroup     String?
  allergies      String?
  isOld          Boolean        @default(false)
  lastVisitDate  DateTime?
  visitCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id])
  appointments   Appointment[]
  diagnoses      Diagnosis[]
  medicalRecord  MedicalRecord?
  procedures     Procedure[]

  @@index([firstName, lastName])
  @@index([phone])
  @@index([status])
  @@index([organizationId])
}

model MedicalRecord {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  assignedDoctorId     String?
  complaints           String?
  insurance            String?
  insuranceNo          String?
  emergencyContactName String?
  emergencyContactNo   String?
  status               String?
  title                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  assignedDoctor       User?    @relation(fields: [assignedDoctorId], references: [id])
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id               String    @id @default(uuid())
  patientId        String
  currentComplaint String?
  pastHistory      String?
  medicalHistory   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  currentHistory   String?
  homeExercise     String?
  icd10Code        String?
  nextVisitDate    DateTime?
  treatmentPlan    String?
  vasScore         Int?      @default(0)
  medicines        String?
  objectiveData    String?
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Appointment {
  id              String       @id @default(uuid())
  organizationId  String
  patientId       String
  doctorId        String?
  appointmentDate DateTime
  status          String
  treatments      String
  isPaid          Boolean      @default(false)
  billAmount      Float        @default(0)
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id])
  doctor          User?        @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedures      Procedure[]

  @@index([organizationId])
}

model BillingCatalog {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  category       String?
  baseCost       Float        @default(0)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

model Procedure {
  id             String       @id @default(uuid())
  organizationId String
  patientId      String
  appointmentId  String?
  name           String
  type           String?
  description    String?
  cost           Float        @default(0)
  procedureDate  DateTime     @default(now())
  medicine       String?
  suggestions    String?
  status         String       @default("PENDING")
  billedById     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([organizationId])
}

model SystemSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  appointmentFee Float        @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}
