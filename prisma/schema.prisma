generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  username        String          @unique
  password        String
  role            Role            @default(RECEPTIONIST)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointments    Appointment[]   @relation("DoctorAppointments")
  assignedRecords MedicalRecord[]
}

model Patient {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  phone         String
  email         String?
  dateOfBirth   DateTime
  gender        String?
  status        String         @default("ACTIVE")
  address       String?
  role          String?
  bloodGroup    String?
  allergies     String?
  isOld         Boolean        @default(false)
  lastVisitDate DateTime?
  visitCount    Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  diagnoses     Diagnosis[]
  medicalRecord MedicalRecord?
  procedures    Procedure[]

  @@index([firstName, lastName])
  @@index([phone])
  @@index([status])
}

model MedicalRecord {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  assignedDoctorId     String?
  complaints           String?
  insurance            String?
  insuranceNo          String?
  emergencyContactName String?
  emergencyContactNo   String?
  status               String?
  title                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  assignedDoctor       User?    @relation(fields: [assignedDoctorId], references: [id])
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id               String    @id @default(uuid())
  patientId        String
  currentComplaint String?
  pastHistory      String?
  medicalHistory   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  currentHistory   String?
  homeExercise     String?
  icd10Code        String?
  nextVisitDate    DateTime?
  treatmentPlan    String?
  vasScore         Int?      @default(0)
  medicines        String?
  objectiveData    String?
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String?
  appointmentDate DateTime
  status          String
  treatments      String
  isPaid          Boolean  @default(false)
  billAmount      Float    @default(0)
  createdAt       DateTime @default(now())
  doctor          User?    @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model BillingCatalog {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String?
  baseCost    Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Procedure {
  id            String   @id @default(uuid())
  patientId     String
  name          String
  type          String?
  description   String?
  cost          Float    @default(0)
  procedureDate DateTime @default(now())
  medicine      String?
  suggestions   String?
  status        String   @default("PENDING")
  billedById    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}
